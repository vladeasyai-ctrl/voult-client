# Local UI → local backend (default)
# NEXT_PUBLIC_API_URL=http://localhost:8080

# Local UI → Cloud Run backend
# NEXT_PUBLIC_API_URL=https://vault-backend-14689299215.europe-west1.run.app

# Google OAuth — same Web Client ID as GOOGLE_CLIENT_ID on the backend.
# Optional if repo-root .env already defines GOOGLE_CLIENT_ID (next.config.ts maps it).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
